{
	"name": "Ubuntu",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"VARIANT": "ubuntu-20.04"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"James-Yu.latex-workshop"
			],
			"settings": {
				"latex-workshop.latex.tools": [
					{
						"name": "pdflatex",
						"command": "pdflatex",
						"args": [
							"-synctex=1",
							"-interaction=nonstopmode",
							"-file-line-error",
							"%DOC%"
						]
					}
				],
				"latex-workshop.latex.recipes": [
					{
						"name": "pdflatex",
						"tools": ["pdflatex"]
					}
				],
				"latex-workshop.latex.autoBuild.run": "onSave"
			}
		}
	},
	"remoteUser": "vscode"
}