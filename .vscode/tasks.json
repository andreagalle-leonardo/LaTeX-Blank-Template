{
    "version": "2.0.0",
    "tasks": [
        {
            // 📄 Standard conversion: Creates a basic Word document from the main.tex file
            "label": "📄 Generate Word (Standard)",
            "type": "shell",
            "command": "pandoc",
            "args": [
                "main.tex",
                "-o",
                "main.docx",
                "--toc" // Automatically generates a Table of Contents in Word
            ],
            "options": {
                // Ensures the command runs in the root folder so \input{} paths work correctly
                "cwd": "${workspaceFolder}" 
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always", // Shows the terminal to let you know it's running
                "panel": "shared",
                "clear": true       // Clears the terminal from previous runs
            },
            "problemMatcher": []
        },
        {
            // 🏢 Template conversion: Applies your company's Word styles (fonts, margins, headers)
            "label": "🏢 Generate Word (Company Template)",
            "type": "shell",
            "command": "pandoc",
            "args": [
                "main.tex",
                "--reference-doc=company_template.docx", // Make sure this file exists in your workspace!
                "-o",
                "main.docx",
                "--toc"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}